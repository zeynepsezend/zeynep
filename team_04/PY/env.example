# LLM Provider Configuration
# Options: local, cloudflare, openai, google, anthropic
LLM_PROVIDER=openai

# OpenAI Configuration (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo

# Anthropic Configuration (if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-opus-4-1

# Google Configuration (if LLM_PROVIDER=google)
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_MODEL=gemini-pro

# Cloudflare Configuration (if LLM_PROVIDER=cloudflare)
# CF_API_TOKEN=your-cloudflare-token
# CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_MODEL=@cf/mistral/mistral-7b-instruct-v0.1

# Local LLM Configuration (if LLM_PROVIDER=local)
# LOCAL_LLM_ENDPOINT=http://localhost:8000

# Workflow Configuration
DEBUG_GRAPH=true
REQUEST_TIMEOUT_SECONDS=30
MAX_ITERATIONS=10
MAX_DESIGN_ITERATIONS=5
