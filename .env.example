## LLM Provider Options
# "local"       → OpenAI-compatible local server (e.g. LM Studio, Ollama)
# "google"      → Google Gemini via google-genai SDK
# "cloudflare"  → Cloudflare Workers AI (free tier, no credit card needed)
# "openai"      → OpenAI API
# "anthropic"   → Anthropic API (Not currently supported due to not handling JSON responses correctly)

LLM_PROVIDER = "local"

# Local LLM (OpenAI-compatible endpoint, e.g. LM Studio)
LOCAL_LLM_ENDPOINT    = "http://localhost:1234/v1/"

# Google API
GOOGLE_API_KEY = "your_google_api_key"
GOOGLE_MODEL = "gemini-2.5-flash-lite"

# Cloudflare Workers AI 
CF_ACCOUNT_ID = "your_cloudflare_account_id"
CF_API_TOKEN  = "your_cloudflare_api_token"
CF_MODEL      = "@cf/qwen/qwen3-30b-a3b-fp8"

# OpenAI API 
OPENAI_API_KEY = "your_openai_api_key"
OPENAI_MODEL = "gpt-5-nano"

# Anthropic API 
ANTHROPIC_API_KEY = "your_anthropic_api_key"
ANTHROPIC_MODEL = "claude-haiku-4-5"

# Tavily API (For web searches)
TAVILY_API_KEY = ""

# Debugging and Iteration Settings 
DEBUG_GRAPH="true" 
# Set to "true" to print StateGraph step traces

MAX_ITERATIONS="100" 
# Maximum number of iterations for the StateGraph
